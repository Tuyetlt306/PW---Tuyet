const scores = [85, 90, 70];
const ages = [18, 21, 16, 25];
const words = ['apple', 'banana', 'cherry', 'date'];

//2.1. Filter values > 80
let scores1 = scores.filter(n => n > 80);
console.log(scores1);
//2.2. Filter values >= 18
let ages1 = ages.filter(n => n >= 18);
console.log(ages1);
//2.3. Values have length > 5
let words1 = words.filter(n => n.length > 5);
console.log(words1);